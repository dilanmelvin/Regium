{
  "name": "@regium/countries",
  "version": "0.2.0",
  "description": "Master country registry — all countries with detailed T1 overrides.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@regium/types": "workspace:*",
    "@regium/country-data": "workspace:*",
    "@regium/country-in": "workspace:*",
    "@regium/country-us": "workspace:*",
    "@regium/country-uk": "workspace:*",
    "@regium/country-de": "workspace:*",
    "@regium/country-fr": "workspace:*",
    "@regium/country-sg": "workspace:*",
    "@regium/country-ae": "workspace:*",
    "@regium/country-br": "workspace:*",
    "@regium/country-au": "workspace:*",
    "@regium/country-ca": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.2",
    "rimraf": "^6.0.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
