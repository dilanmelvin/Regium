{
  "name": "@regium/country-sg",
  "version": "0.1.0",
  "description": "Regium country pack for Singapore (SG).",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "sideEffects": false,
  "scripts": { "build": "tsup", "typecheck": "tsc --noEmit", "clean": "rimraf dist" },
  "dependencies": { "@regium/types": "workspace:*", "@regium/validators": "workspace:*" },
  "devDependencies": { "tsup": "^8.3.0", "typescript": "^5.6.2", "rimraf": "^6.0.1" },
  "publishConfig": { "access": "public" }
}
