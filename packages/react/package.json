{
  "name": "@regium/react",
  "version": "0.2.0",
  "description": "React adapter for Regium — hooks, context, headless components.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@regium/core": "workspace:*",
    "@regium/types": "workspace:*",
    "@regium/forms": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.2",
    "rimraf": "^6.0.1",
    "react": "^18.3.1",
    "@types/react": "^18.3.11"
  },
  "publishConfig": {
    "access": "public"
  }
}
