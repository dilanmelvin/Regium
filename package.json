{
  "name": "regium",
  "version": "0.1.0",
  "private": true,
  "description": "Global workforce compliance infrastructure for developers.",
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=18.17"
  },
  "workspaces": ["apps/*", "packages/*", "tools/*"],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "turbo run test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rimraf node_modules",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo run build && changeset publish",
    "playground": "pnpm --filter @regium/playground dev"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.27.9",
    "@types/node": "^20.16.10",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.0",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2",
    "zod": "^3.23.8"
  }
}
